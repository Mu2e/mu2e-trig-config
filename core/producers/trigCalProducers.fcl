#include "Offline/CaloReco/fcl/common.fcl"

BEGIN_PROLOG

TrigCalProducers : {
  CaloCosmicTriggerInfoMerger: {
    module_type: "MergeTriggerInfo"
  }
  CaloNNCETriggerInfoMerger: {
    module_type: "MergeTriggerInfo"
  }
  CaloPhotonTriggerInfoMerger: {
    module_type: "MergeTriggerInfo"
  }
  CaloRMCTriggerInfoMerger: {
    module_type: "MergeTriggerInfo"
  }
  CaloCluster50TriggerInfoMerger: {
    module_type: "MergeTriggerInfo"
  }
  CaloCluster60TriggerInfoMerger: {
    module_type: "MergeTriggerInfo"
  }
  CaloCluster70TriggerInfoMerger: {
    module_type: "MergeTriggerInfo"
  }
  CaloCluster75TriggerInfoMerger: {
    module_type: "MergeTriggerInfo"
  }
  CaloCluster80TriggerInfoMerger: {
    module_type: "MergeTriggerInfo"
  }


  CaloHitMakerFast:
  {
    module_type   : "CaloHitsFromDTCEvents"
    diagLevel     : 0
    digiSampling  : 5
    deltaTPulses  : 5.
    nPEperMeV     : 30
    noiseLevelMeV : 0.55
    nSigmaNoise   : 4
    # hitEDepMax    : 80.
    hitEDepMax    : 1000. # for testing
    hitEDepMin    : 1.0
    caphriEDepMax : 5.0 #MeV
    caphriEDepMin : 1.0 #MeV
    ADCToMeV      : @local::ADCToMeV
  }

  CaloHitMakerFastFromDigi: {
    module_type: "CaloHitMakerFast"
    ProtonBunchTimeTag: "EWMProducer"
    caloDigiCollection: "CaloDigiMaker"
    deltaTPulses: 11
    diagLevel: 0
    digiSampling: 5
    nPEperMeV: 30
    nSigmaNoise: 4
    noiseLevelMeV: 5.5e-1
    caphriEDepMin : 1.
    caphriEDepMax : 5.
    ADCToMeV      : @local::ADCToMeV
  }


  CaloClusterFast: {
    EminSeed: 10
    EnoiseCut: 1
    ExpandCut: 1
    caloHitCollection: "CaloHitMakerFast:calo"
    deltaTime: 10
    diagLevel: 0
    extendSearch: true
    minSiPMPerHit: 2
    module_label: "CaloClusterFast"
    module_type: "CaloClusterFast"
    timeOffset: -61
  }

  CaloNNCEEval: {
    caloBkgMVA: {
      MVAWeights: "Offline/CaloFilters/data/CE_NN_ReLU_noET.weights.xml"
    }
    caloClusterCollection: "CaloClusterFast"
    diagLevel: 0
    minEtoTest: 60
    maxEtoTest: 2000
    minTtoTest: 0
    maxTtoTest: 1600
    minRtoTest: 0
    maxRtoTest: 1000
    module_type: "CaloNNEval"
  }




}

END_PROLOG
